---
import Layout from "../../layouts/Layout.astro";
import CalculatorShell from "../../components/calculators/CalculatorShell.astro";
import InputNumber from "../../components/calculators/InputNumber.astro";
import Select from "../../components/calculators/Select.astro";
import CurrencyToggle from "../../components/calculators/CurrencyToggle.astro";
import BinaryToggle from "../../components/calculators/BinaryToggle.astro";
import RelatedTools from "../../components/RelatedTools.astro";
import ToolContent from "../../components/ToolContent.astro";
import { breadcrumbSchema } from "../../lib/seo/breadcrumbSchema";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const breadcrumbs = [
    { name: "Inicio", url: "/" },
    { name: "Calculadoras", url: "/calculadoras" },
    {
        name: "Horas Extra",
        url: "/calculadoras/horas-extra-uruguay",
    },
];

const schema = breadcrumbSchema(breadcrumbs);

const surchargeOptions = [
    { label: "Hora Extra Simple (100%)", value: 1.0 }, // Recargo del 100% (vale el doble)
    { label: "Hora Extra en Feriado/Descanso (150%)", value: 1.5 }, // Recargo del 150% (vale 2.5 veces)
];

const nocturnalOptions: [
    { label: string; value: number },
    { label: string; value: number },
] = [
    { label: "No", value: 0 },
    { label: "Sí (+20%)", value: 1 },
];
---

<Layout
    title="Calcular Horas Extra Uruguay - CalculaEasy"
    description="Calculadora de Horas Extra en Uruguay. Calculá el valor de tus horas simples, dobles y feriados."
    canonical="https://calculaeasy.com/calculadoras/horas-extra-uruguay"
    schema={schema}
>
    <div class="bg-indigo-50 min-h-screen py-12">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
            <Breadcrumbs items={breadcrumbs} />

            <CalculatorShell
                title="Calculadora de Horas Extra"
                description="Calculá el valor de tus horas extra según tu sueldo y el tipo de recargo."
            >
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                    <!-- Form -->
                    <div class="space-y-6">
                        <InputNumber
                            label="Sueldo Nominal Mensual"
                            name="monthlyNominal"
                            placeholder="Ej: 30000"
                            min={0}
                        />

                        <CurrencyToggle label="Moneda" name="currency" />

                        <div id="exchange-rate-container" class="hidden">
                            <InputNumber
                                label="Cotización Dólar"
                                name="exchangeRate"
                                value={40}
                                min={1}
                            />
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <InputNumber
                                label="Horas Mensuales"
                                name="monthlyHours"
                                value={192}
                                min={1}
                            />
                            <InputNumber
                                label="Cantidad de Horas Extra"
                                name="overtimeHours"
                                placeholder="Ej: 5"
                                min={0}
                            />
                        </div>

                        <Select
                            label="Tipo de Hora Extra"
                            name="surchargeRate"
                            options={surchargeOptions}
                        />

                        <BinaryToggle
                            label="¿Horario nocturno?"
                            name="nocturnal"
                            options={nocturnalOptions}
                            selected={0}
                        />
                    </div>

                    <!-- Results -->
                    <div class="space-y-6">
                        <div
                            class="bg-indigo-900 rounded-2xl p-6 sm:p-8 text-white relative overflow-hidden shadow-lg"
                        >
                            <div
                                class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-indigo-500 rounded-full opacity-20 blur-xl"
                            >
                            </div>

                            <div class="relative z-10">
                                <p
                                    class="text-indigo-200 text-sm font-medium uppercase tracking-wider mb-1"
                                >
                                    Total a Cobrar (Extra)
                                </p>
                                <div class="flex items-baseline gap-1">
                                    <span
                                        class="text-4xl sm:text-5xl font-bold"
                                        id="result-total">$ 0</span
                                    >
                                </div>
                                <div
                                    class="mt-4 grid grid-cols-2 gap-4 text-sm"
                                >
                                    <div>
                                        <p class="text-indigo-300">
                                            Valor Hora Simple
                                        </p>
                                        <p
                                            class="font-semibold text-lg"
                                            id="result-hourly-rate"
                                        >
                                            $ 0
                                        </p>
                                    </div>
                                    <div>
                                        <p class="text-indigo-300">
                                            Valor Hora Extra
                                        </p>
                                        <p
                                            class="font-semibold text-lg"
                                            id="result-overtime-rate"
                                        >
                                            $ 0
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div
                            id="uyu-equivalent"
                            class="hidden p-4 bg-emerald-50 rounded-xl border border-emerald-100 text-sm text-emerald-800"
                        >
                            <p>
                                <strong>Equivalente en pesos:</strong> el total a
                                cobrar son aproximadamente <span
                                    id="result-total-uyu"
                                    class="font-semibold">$ 0</span
                                > a la cotización ingresada.
                            </p>
                        </div>

                        <ul
                            id="result-notes"
                            class="hidden space-y-1.5 text-sm text-slate-500 list-disc pl-5"
                        >
                        </ul>

                        <div
                            class="p-4 bg-blue-50 rounded-xl border border-blue-100 text-sm text-blue-800"
                        >
                            <p>
                                <strong>Nota:</strong> Las horas extras llevan aportes
                                jubilatorios y FONASA igual que el sueldo, y también
                                suman para IRPF. El valor hora surge de dividir el sueldo
                                nominal entre las horas mensuales (por defecto 192 = 24
                                jornadas de 8 h). El cálculo es estimativo y puede variar
                                según convenio o empresa.
                            </p>
                        </div>
                    </div>
                </div>
            </CalculatorShell>
            <ToolContent toolId="horas-extra-uruguay" />
            <RelatedTools currentTool="horas-extra-uruguay" />
        </div>
    </div>
</Layout>

<script>
    import { calculateOvertime } from "../../lib/calculations/uy/salary/overtime";
    import { formatUYU, formatUSD } from "../../lib/calculations/utils";

    const inputNominal = document.querySelector(
        'input[name="monthlyNominal"]',
    ) as HTMLInputElement;
    const inputCurrency = document.querySelector(
        'select[name="currency"]',
    ) as HTMLSelectElement;
    const inputExchangeRate = document.querySelector(
        'input[name="exchangeRate"]',
    ) as HTMLInputElement;
    const exchangeRateContainer = document.getElementById(
        "exchange-rate-container",
    );
    const inputMonthlyHours = document.querySelector(
        'input[name="monthlyHours"]',
    ) as HTMLInputElement;
    const inputOvertimeHours = document.querySelector(
        'input[name="overtimeHours"]',
    ) as HTMLInputElement;
    const selectSurcharge = document.querySelector(
        'select[name="surchargeRate"]',
    ) as HTMLSelectElement;
    const selectNocturnal = document.querySelector(
        'select[name="nocturnal"]',
    ) as HTMLSelectElement;

    const resultTotal = document.getElementById("result-total");
    const resultHourlyRate = document.getElementById("result-hourly-rate");
    const resultOvertimeRate = document.getElementById("result-overtime-rate");
    const uyuEquivalent = document.getElementById("uyu-equivalent");
    const resultTotalUyu = document.getElementById("result-total-uyu");
    const resultNotes = document.getElementById("result-notes");

    function toggleExchangeRate() {
        if (inputCurrency.value === "USD") {
            exchangeRateContainer?.classList.remove("hidden");
        } else {
            exchangeRateContainer?.classList.add("hidden");
        }
        recalculate();
    }

    function recalculate() {
        const monthlyNominal = parseFloat(inputNominal.value) || 0;
        const currency = (inputCurrency.value as "UYU" | "USD") || "UYU";
        const exchangeRate = parseFloat(inputExchangeRate.value) || 40;
        const monthlyHours = parseFloat(inputMonthlyHours.value) || 192;
        const overtimeHours = parseFloat(inputOvertimeHours.value) || 0;
        const surchargeRate = parseFloat(selectSurcharge.value) || 1.0;
        const nocturnal = selectNocturnal.value === "1";

        const result = calculateOvertime({
            monthlyNominal,
            currency,
            exchangeRate,
            monthlyHours,
            overtimeHours,
            surchargeRate,
            nocturnal,
        });

        const format = currency === "USD" ? formatUSD : formatUYU;

        if (resultTotal) resultTotal.innerText = format(result.overtimePay);
        if (resultHourlyRate)
            resultHourlyRate.innerText = format(result.hourlyRate);
        if (resultOvertimeRate)
            resultOvertimeRate.innerText = format(result.overtimeHourlyRate);

        // Equivalente en pesos: solo aplica cuando se ingresa en USD.
        if (currency === "USD" && result.overtimePayInUYU !== undefined) {
            if (resultTotalUyu)
                resultTotalUyu.innerText = formatUYU(result.overtimePayInUYU);
            uyuEquivalent?.classList.remove("hidden");
        } else {
            uyuEquivalent?.classList.add("hidden");
        }

        // Notas dinámicas devueltas por el cálculo.
        if (resultNotes) {
            resultNotes.innerHTML = result.notes
                .map((note) => `<li>${note}</li>`)
                .join("");
            resultNotes.classList.toggle("hidden", result.notes.length === 0);
        }
    }

    // Listeners
    inputNominal?.addEventListener("input", recalculate);
    inputCurrency?.addEventListener("change", toggleExchangeRate);
    inputExchangeRate?.addEventListener("input", recalculate);
    inputMonthlyHours?.addEventListener("input", recalculate);
    inputOvertimeHours?.addEventListener("input", recalculate);
    selectSurcharge?.addEventListener("change", recalculate);
    selectNocturnal?.addEventListener("change", recalculate);

    // Cálculo inicial para mostrar el valor hora apenas carga la página.
    recalculate();
</script>
